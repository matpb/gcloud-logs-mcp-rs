# Server binding
MCP_HOST=0.0.0.0
MCP_PORT=8432

# Logging
RUST_LOG=gcloud_logs_mcp=info

# Log query limits
DEFAULT_LOG_LIMIT=100
MAX_LOG_LIMIT=1000

# Path to credentials directory (mounted in Docker)
CREDENTIALS_DIR=./credentials

# GCP Projects configuration (JSON array)
# Each project needs: name (friendly identifier), project_id (GCP project ID)
# Optional: credentials_file (path to service account JSON key)
# If credentials_file is omitted, falls back to GOOGLE_APPLICATION_CREDENTIALS or ADC
GCP_PROJECTS='[{"name":"siku-dev","project_id":"dev-siku-org","credentials_file":"/credentials/dev-sa.json"},{"name":"siku-prod","project_id":"arctic-eider-414","credentials_file":"/credentials/prod-sa.json"}]'
